# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cfdi_comparator
MONGODB_URI_TEST=mongodb://localhost:27017/cfdi_comparator_test

# Auth0
# Dominio del tenant (sin https://)
AUTH0_DOMAIN=dev-1sol0n0owkx7ho82.us.auth0.com
# API Identifier registrado en Auth0 → Applications > APIs
# NOTA: debe coincidir con el audience del API registrado (no el Management API /api/v2/)
AUTH0_AUDIENCE=koreacc
# Client ID de la SPA Application — va en environment.ts del frontend, no aquí
# AUTH0_CLIENT_ID=<obtener de Auth0 Dashboard → Applications → tu SPA>

# JWT (legacy — solo si no se usa Auth0)
JWT_SECRET=tu_secreto_muy_seguro_aqui
JWT_EXPIRES_IN=24h

# SAT Web Services
SAT_VERIFICA_CFDI_WSDL=https://verificacfdi.facturaelectronica.sat.gob.mx/default.aspx?wsdl
SAT_DESCARGA_MASIVA_AUTENTICACION=https://cfdidescargamasiva.clouda.sat.gob.mx/AutenticaService.svc?wsdl
SAT_DESCARGA_MASIVA_SOLICITUD=https://cfdidescargamasiva.clouda.sat.gob.mx/SolicitudService.svc?wsdl
SAT_DESCARGA_MASIVA_VERIFICA=https://cfdidescargamasiva.clouda.sat.gob.mx/VerificaSolicitudDescargaService.svc?wsdl
SAT_DESCARGA_MASIVA_DESCARGA=https://cfdidescargamasiva.clouda.sat.gob.mx/DescargaMasivaService.svc?wsdl

# FIEL (Firma Electrónica Avanzada) — requerida para Descarga Masiva
FIEL_CER_PATH=./certs/fiel.cer
FIEL_KEY_PATH=./certs/fiel.key
FIEL_KEY_PASSWORD=tu_password_fiel

# ERP Integration
# URL base del ERP sin trailing slash. Ej: https://api.miERP.com/v1
ERP_BASE_URL=
# Token Bearer para autenticación (se envía como Authorization: Bearer <token>)
ERP_TOKEN=

# Google Drive — Service Account (uno de los dos)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# OCR / Análisis de comprobantes
# Motor de extracción: 'tesseract' (local, gratis) o 'claude' (API, mayor precisión)
RECEIPT_OCR_ENGINE=tesseract
# Requerido solo cuando RECEIPT_OCR_ENGINE=claude
ANTHROPIC_API_KEY=
# Modelo Claude a usar (claude-haiku-4-5-20251001 = más barato, claude-sonnet-4-6 = más preciso)
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log
